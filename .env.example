# Copy this to .env.local and set allowed hostnames for Vite dev/preview
# Comma-separated list (no protocol)
VITE_ALLOWED_HOSTS=your-hostname.example.com,192.168.67.199

# Allowed browser origins for sync API CORS (comma-separated, include protocol)
SYNC_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.67.199:3000,https://your-hostname.example.com