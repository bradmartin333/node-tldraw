# Copy this to .env. Never commit .env.

# Hostnames Vite will serve (comma-separated, no protocol)
VITE_ALLOWED_HOSTS=your-hostname.example.com,192.168.1.238

# Allowed browser origins for sync API CORS (comma-separated, include protocol)
SYNC_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.238:3000,https://your-hostname.example.com
