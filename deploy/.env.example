# Optional. Copy to `.env` next to docker-compose.yml.
# Not needed at all if you only reach the app at http://localhost:3000.

# Hostnames Vite will serve. Bare hostnames — no protocol, no port.
# Defaults to "*" (allow any) when unset, which is fine behind a trusted proxy;
# set it explicitly to tighten the check.
VITE_ALLOWED_HOSTS=devtools.example.com,192.168.1.10

# REQUIRED once the app is reached by anything other than localhost.
# The sync server ships with a localhost-only CORS allowlist, so every board
# write (POST/PATCH/DELETE) returns 403 "Origin is not allowed" from another
# origin — reads keep working, which makes this fail confusingly. List every
# origin the browser may use, including scheme and any non-default port.
SYNC_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://devtools.example.com:3000,https://devtools.example.com

# Optional: require a bearer token for board writes.
# SYNC_WRITE_TOKEN=

# NOTE: there are no VITE_BRAND_LOGO_* variables. Vite inlines VITE_* values at
# image build time, so they cannot be set at `docker run` against the published
# image. To rebrand, mount your own logo files over the bundled ones — see the
# commented-out volume lines in docker-compose.yml.
